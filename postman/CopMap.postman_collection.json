{
  "info": {
    "name": "CopMap Backend",
    "description": "Authored by Krishnamurti. End-to-end collection covering auth, patrols, bandobast/nakabandi, assignments, locations, alerts, and PDF reports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "plannerToken", "value": "" },
    { "key": "officerToken", "value": "" },
    { "key": "patrolId", "value": "" },
    { "key": "bandobastId", "value": "" },
    { "key": "officerId", "value": "" },
    { "key": "assignmentId", "value": "" },
    { "key": "alertId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (planner)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json(); pm.collectionVariables.set('plannerToken', j.token); pm.collectionVariables.set('token', j.token);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"planner\",\n  \"password\": \"copmap123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Login (officer1)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const j = pm.response.json(); pm.collectionVariables.set('officerToken', j.token);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"officer1\",\n  \"password\": \"copmap123\"\n}" },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Register (supervisor-only typical)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"officer3\",\n  \"password\": \"copmap123\",\n  \"fullName\": \"Constable Kumar\",\n  \"badgeNumber\": \"O-203\",\n  \"phone\": \"+910000000005\",\n  \"role\": \"OFFICER\"\n}" },
            "url": "{{baseUrl}}/api/auth/register"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        { "name": "Me", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/users/me" } },
        { "name": "List officers",
          "event": [{ "listen": "test", "script": { "exec": [
            "const arr = pm.response.json(); if (arr.length) pm.collectionVariables.set('officerId', arr[0].id);"
          ], "type": "text/javascript" } }],
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{plannerToken}}" }], "url": "{{baseUrl}}/api/users/officers" } }
      ]
    },
    {
      "name": "Patrols",
      "item": [
        {
          "name": "Create patrol",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.collectionVariables.set('patrolId', pm.response.json().id);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{plannerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Andheri West night beat\",\n  \"description\": \"Routine foot patrol\",\n  \"beatName\": \"AW-07\",\n  \"startAt\": \"2026-04-23T20:00:00Z\",\n  \"endAt\": \"2026-04-24T02:00:00Z\",\n  \"checkpoints\": [\n    { \"sequence\": 1, \"name\": \"Station\", \"latitude\": 19.136, \"longitude\": 72.826, \"radiusMeters\": 100, \"dueOffsetMinutes\": 15 },\n    { \"sequence\": 2, \"name\": \"Market Junction\", \"latitude\": 19.140, \"longitude\": 72.830, \"radiusMeters\": 100, \"dueOffsetMinutes\": 90 }\n  ]\n}" },
            "url": "{{baseUrl}}/api/patrols"
          }
        },
        { "name": "List patrols", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/patrols" } },
        { "name": "Get patrol", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/patrols/{{patrolId}}" } },
        {
          "name": "Assign officer",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.collectionVariables.set('assignmentId', pm.response.json().id);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{plannerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"officerId\": \"{{officerId}}\",\n  \"role\": \"BEAT_OFFICER\"\n}" },
            "url": "{{baseUrl}}/api/patrols/{{patrolId}}/assignments"
          }
        },
        { "name": "Start patrol", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{plannerToken}}" }], "url": "{{baseUrl}}/api/patrols/{{patrolId}}/start" } },
        {
          "name": "Close patrol",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{plannerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"notes\": \"All checkpoints covered, nothing to report.\" }" },
            "url": "{{baseUrl}}/api/patrols/{{patrolId}}/close"
          }
        },
        { "name": "Download report (PDF)", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/patrols/{{patrolId}}/report" } }
      ]
    },
    {
      "name": "Bandobast / Nakabandi",
      "item": [
        {
          "name": "Create bandobast",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.collectionVariables.set('bandobastId', pm.response.json().id);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{plannerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"kind\": \"BANDOBAST\",\n  \"title\": \"Ganpati visarjan — Juhu beach\",\n  \"description\": \"Crowd & traffic management\",\n  \"venue\": \"Juhu beach\",\n  \"latitude\": 19.097,\n  \"longitude\": 72.826,\n  \"radiusMeters\": 800,\n  \"startAt\": \"2026-09-17T12:00:00Z\",\n  \"endAt\": \"2026-09-18T00:00:00Z\",\n  \"expectedCrowd\": 20000,\n  \"threatLevel\": \"MEDIUM\"\n}" },
            "url": "{{baseUrl}}/api/bandobast"
          }
        },
        {
          "name": "Create nakabandi",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{plannerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"kind\": \"NAKABANDI\",\n  \"title\": \"Highway-48 night checking\",\n  \"venue\": \"Manor toll plaza\",\n  \"latitude\": 19.720,\n  \"longitude\": 72.780,\n  \"radiusMeters\": 200,\n  \"startAt\": \"2026-04-23T22:00:00Z\",\n  \"endAt\": \"2026-04-24T05:00:00Z\",\n  \"threatLevel\": \"LOW\"\n}" },
            "url": "{{baseUrl}}/api/bandobast"
          }
        },
        { "name": "List bandobast", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/bandobast" } },
        {
          "name": "Assign officer to bandobast",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{plannerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"officerId\": \"{{officerId}}\", \"role\": \"NAKA_LEAD\" }" },
            "url": "{{baseUrl}}/api/bandobast/{{bandobastId}}/assignments"
          }
        },
        { "name": "Download plan (PDF)", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }], "url": "{{baseUrl}}/api/bandobast/{{bandobastId}}/plan" } }
      ]
    },
    {
      "name": "Officer actions",
      "item": [
        { "name": "My assignments", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{officerToken}}" }], "url": "{{baseUrl}}/api/assignments/mine" } },
        { "name": "Acknowledge", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{officerToken}}" }], "url": "{{baseUrl}}/api/assignments/{{assignmentId}}/acknowledge" } },
        { "name": "Check-in", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{officerToken}}" }], "url": "{{baseUrl}}/api/assignments/{{assignmentId}}/check-in" } },
        { "name": "Check-out", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{officerToken}}" }], "url": "{{baseUrl}}/api/assignments/{{assignmentId}}/check-out" } },
        {
          "name": "Send GPS ping",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{officerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"latitude\": 19.136, \"longitude\": 72.826, \"accuracyMeters\": 8, \"speedMps\": 1.2, \"batteryPct\": 74 }" },
            "url": "{{baseUrl}}/api/locations/ping"
          }
        }
      ]
    },
    {
      "name": "Live monitoring",
      "item": [
        { "name": "Live locations", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{plannerToken}}" }], "url": "{{baseUrl}}/api/locations/live" } },
        { "name": "Officer history",
          "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{plannerToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/locations/officers/{{officerId}}/history?from=2026-04-23T00:00:00Z&to=2026-04-24T00:00:00Z",
              "host": ["{{baseUrl}}"], "path": ["api","locations","officers","{{officerId}}","history"],
              "query": [ { "key": "from", "value": "2026-04-23T00:00:00Z" }, { "key": "to", "value": "2026-04-24T00:00:00Z" } ] } } }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "Raise alert (officer PANIC)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.collectionVariables.set('alertId', pm.response.json().id);"
          ], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{officerToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ \"type\": \"PANIC\", \"severity\": \"CRITICAL\", \"message\": \"Need backup\", \"latitude\": 19.136, \"longitude\": 72.826 }" },
            "url": "{{baseUrl}}/api/alerts"
          }
        },
        { "name": "List open", "request": { "method": "GET", "header": [{ "key": "Authorization", "value": "Bearer {{plannerToken}}" }], "url": "{{baseUrl}}/api/alerts/open" } },
        { "name": "Acknowledge alert", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{plannerToken}}" }], "url": "{{baseUrl}}/api/alerts/{{alertId}}/acknowledge" } },
        { "name": "Resolve alert", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{plannerToken}}" }], "url": "{{baseUrl}}/api/alerts/{{alertId}}/resolve" } }
      ]
    }
  ]
}
